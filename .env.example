# ============================================================
# Variáveis de Ambiente - copie para .env.local para dev local
# Configure estas variáveis no painel da Vercel em Settings > Environment Variables
# ============================================================

# Banco de dados Neon (obrigatório)
# Encontre em: neon.tech > seu projeto > Connection Details > Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Segredo JWT - gere um token aleatório seguro de pelo menos 32 caracteres
# Gere com: openssl rand -base64 32
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-forte-32chars

# Segredo para registrar novos usuários após o primeiro admin
# Use como header: X-Registration-Secret: valor-aqui
REGISTRATION_SECRET=outra-chave-secreta-para-registro

# (Opcional) Restrição de origem CORS - coloque seu domínio Vercel
# ALLOWED_ORIGIN=https://seu-site.vercel.app
